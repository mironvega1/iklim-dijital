---
const services = [
  "Klima bakım",
  "Klima temizlik",
  "Klima arıza",
  "Klima montaj / sökme-takma",
  "Hepsi",
];

const toolCards = [
  {
    title: "Bütçe gerçekliğini gösterir",
    text: "Günlük bütçenin ay sonunda neye dönüştüğünü netleştirir.",
  },
  {
    title: "Mesaj maliyeti hedefini belirler",
    text: "Reklamın sağlıklı çalışması için takip edilmesi gereken mesaj maliyeti aralığını gösterir.",
  },
  {
    title: "Amorti mantığını gösterir",
    text: "Ortalama servis bedeline göre reklam bütçesinin kaç işle karşılanabileceğini tahmini olarak gösterir.",
  },
  {
    title: "İlk reklam açısını önerir",
    text: "Bakım, temizlik, arıza veya montaj hizmetine göre hangi kreatif açısıyla başlanabileceğini önerir.",
  },
  {
    title: "Görüşme öncesi hazırlık sağlar",
    text: "Firma sahibi başvuru yapmadan önce bütçe ve hizmet önceliğini daha net görür.",
  },
];
---

<section id="simulator" class="py-20 md:py-28">
  <div class="section-shell">
    <div class="mb-12 max-w-4xl">
      <p class="inline-flex rounded-full border border-lime/30 bg-lime/10 px-4 py-2 text-xs font-black uppercase text-lime">
        Müşteri Akışı Simülatörü
      </p>
      <h2 class="mt-5 text-balance text-3xl font-black leading-tight text-white md:text-5xl">
        Klima firmanız için potansiyel müşteri akışını hesaplayın
      </h2>
      <p class="mt-5 text-base leading-8 text-textMuted md:text-lg">
        Günlük reklam bütçenizi, hizmet bölgenizi ve ortalama servis bedelinizi girin. Reklam sürecinde hangi mesaj maliyetinin hedeflenmesi gerektiğini ve birkaç işin sistemi nasıl karşılayabileceğini tahmini olarak görün.
      </p>
    </div>

    <div class="glass-panel relative overflow-hidden rounded-[8px] p-5 md:p-8" data-growth-simulator>
      <div class="absolute right-0 top-0 h-80 w-80 translate-x-1/2 -translate-y-1/2 rounded-full bg-lime/20 blur-3xl"></div>
      <div class="relative grid gap-8 lg:grid-cols-[0.92fr_1.08fr]">
        <div class="rounded-[8px] border border-white/10 bg-[#0d0d0d] p-5 md:p-6">
          <div class="mb-6 flex items-center justify-between gap-4">
            <div>
              <p class="text-xs font-black uppercase text-lime">Tahmini reklam senaryosu</p>
              <h3 class="mt-1 text-2xl font-black text-white">Reklam verirseniz ne olabilir?</h3>
            </div>
            <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-[11px] font-bold uppercase text-textMuted">
              Kural bazlı hesaplama
            </span>
          </div>

          <div class="space-y-5">
            <label class="block">
              <span class="flex items-center justify-between gap-3 text-sm font-bold text-white">
                Günlük reklam bütçesi
                <strong class="text-lime" data-daily-label>500 TL</strong>
              </span>
              <input data-daily type="range" min="300" max="3000" step="100" value="500" class="mt-3 w-full accent-lime" />
            </label>

            <label class="block">
              <span class="text-sm font-bold text-white">Hizmet verilen şehir / ilçe</span>
              <input data-area type="text" class="mt-2 h-12 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 text-sm text-white outline-none transition placeholder:text-textMuted focus:border-lime/50" placeholder="Örn: Muğla / Bodrum" />
            </label>

            <label class="block">
              <span class="text-sm font-bold text-white">En çok müşteri istenen hizmet</span>
              <select data-service class="mt-2 h-12 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 text-sm text-white outline-none transition focus:border-lime/50">
                {services.map((service) => <option value={service}>{service}</option>)}
              </select>
            </label>

            <label class="block">
              <span class="flex items-center justify-between gap-3 text-sm font-bold text-white">
                Ortalama servis bedeli
                <strong class="text-lime" data-service-price-label>1.500 TL</strong>
              </span>
              <input data-service-price type="range" min="500" max="10000" step="100" value="1500" class="mt-3 w-full accent-lime" />
            </label>

            <label class="block">
              <span class="flex items-center justify-between gap-3 text-sm font-bold text-white">
                Hedef mesaj başı maliyet
                <strong class="text-lime" data-cost-label>50 TL</strong>
              </span>
              <input data-cost type="range" min="15" max="200" step="5" value="50" class="mt-3 w-full accent-lime" />
            </label>
          </div>
        </div>

        <div>
          <div class="mb-5 grid grid-cols-4 gap-2 rounded-[8px] border border-lime/20 bg-lime/[0.06] p-3 text-center text-[11px] font-black uppercase text-white/80">
            <span>Bütçe</span>
            <span>Mesaj</span>
            <span>Randevu</span>
            <span>Servis</span>
          </div>

          <div class="grid gap-3 md:grid-cols-2">
            <article class="rounded-[8px] border border-white/10 bg-[#151515] p-5">
              <p class="text-xs font-bold uppercase text-textMuted">Aylık reklam bütçesi</p>
              <p class="mt-3 text-3xl font-black text-white" data-monthly-budget>15.000 TL</p>
              <p class="mt-2 text-xs leading-6 text-textMuted">Günlük bütçenin 30 günlük tahmini karşılığı.</p>
            </article>
            <article class="rounded-[8px] border border-white/10 bg-[#151515] p-5">
              <p class="text-xs font-bold uppercase text-textMuted">Tahmini mesaj potansiyeli</p>
              <p class="mt-3 text-3xl font-black text-white" data-estimated-messages>300 mesaj</p>
              <p class="mt-2 text-xs leading-6 text-textMuted">Hedef mesaj maliyetine göre hesaplanan tahmini mesaj potansiyeli.</p>
            </article>
            <article class="rounded-[8px] border border-white/10 bg-[#151515] p-5">
              <p class="text-xs font-bold uppercase text-textMuted">Kendini karşılaması için</p>
              <p class="mt-3 text-3xl font-black text-white" data-break-even>10 iş</p>
              <p class="mt-2 text-xs leading-6 text-textMuted">Reklam bütçesini karşılamak için gereken yaklaşık iş sayısı.</p>
            </article>
            <article class="rounded-[8px] border border-lime/25 bg-lime/[0.08] p-5">
              <p class="text-xs font-bold uppercase text-lime">Büyüme senaryosu</p>
              <p class="mt-3 text-2xl font-black leading-tight text-white" data-growth-scenario>15 iş alınırsa 22.500 TL servis hacmi oluşabilir.</p>
              <p class="mt-2 text-xs leading-6 text-textMuted">Yalnızca senaryo amaçlıdır. Gerçek ciro garantisi değildir.</p>
            </article>
          </div>

          <article class="mt-3 rounded-[8px] border border-lime/25 bg-[#101010] p-5">
            <p class="text-xs font-bold uppercase text-lime">Önerilen ilk reklam açısı</p>
            <p class="mt-3 text-lg font-black leading-7 text-white" data-recommendation>
              “Kötü koku / yaz öncesi bakım” açısıyla başlanabilir.
            </p>
            <p class="mt-2 text-xs leading-6 text-textMuted" data-area-note>
              Hizmet bölgesi girildiğinde senaryo o bölge için düşünülür.
            </p>
          </article>

          <p class="mt-5 rounded-[8px] border border-white/10 bg-white/[0.035] p-4 text-xs font-semibold leading-6 text-textMuted">
            Bu hesaplama tahmini bir reklam senaryosudur. Gerçek sonuçlar şehir, sezon, reklam bütçesi, kreatif kalitesi, hizmet bölgesi, firmanın dönüş hızı ve fiyatlandırmasına göre değişebilir. Bu araç satış garantisi değil, reklam planlaması için fikir verir.
          </p>
        </div>
      </div>
    </div>

    <div class="mt-10 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
      {toolCards.map((card) => (
        <article class="premium-card rounded-[8px] p-5">
          <h3 class="text-base font-black text-white">{card.title}</h3>
          <p class="mt-3 text-xs font-semibold leading-6 text-textMuted">{card.text}</p>
        </article>
      ))}
    </div>
  </div>

  <script>
    const recommendations = {
      "Klima bakım": "“Kötü koku / yaz öncesi bakım” açısıyla başlanabilir.",
      "Klima temizlik": "“Filtre ve iç ünite temizliği” farkındalık kreatifi denenebilir.",
      "Klima arıza": "“Soğutmuyor / su akıtıyor / ses yapıyor” problem odaklı reklam açısı denenebilir.",
      "Klima montaj / sökme-takma": "“Yeni klima montajı / taşınma sonrası sökme-takma” açısı denenebilir.",
      Hepsi: "“Bakım, arıza ve montaj için ayrı reklam açılarıyla başlanmalı.”",
    };

    const formatTRY = (value) => new Intl.NumberFormat("tr-TR").format(value) + " TL";

    document.querySelectorAll("[data-growth-simulator]").forEach((panel) => {
      if (!(panel instanceof HTMLElement) || panel.dataset.bound === "true") return;
      panel.dataset.bound = "true";

      const daily = panel.querySelector("[data-daily]");
      const area = panel.querySelector("[data-area]");
      const service = panel.querySelector("[data-service]");
      const servicePrice = panel.querySelector("[data-service-price]");
      const cost = panel.querySelector("[data-cost]");
      const dailyLabel = panel.querySelector("[data-daily-label]");
      const servicePriceLabel = panel.querySelector("[data-service-price-label]");
      const costLabel = panel.querySelector("[data-cost-label]");
      const monthlyBudget = panel.querySelector("[data-monthly-budget]");
      const estimatedMessages = panel.querySelector("[data-estimated-messages]");
      const breakEven = panel.querySelector("[data-break-even]");
      const growthScenario = panel.querySelector("[data-growth-scenario]");
      const recommendation = panel.querySelector("[data-recommendation]");
      const areaNote = panel.querySelector("[data-area-note]");

      const update = () => {
        if (
          !(daily instanceof HTMLInputElement) ||
          !(area instanceof HTMLInputElement) ||
          !(service instanceof HTMLSelectElement) ||
          !(servicePrice instanceof HTMLInputElement) ||
          !(cost instanceof HTMLInputElement)
        ) {
          return;
        }

        const dailyBudget = Number(daily.value);
        const averageServicePrice = Number(servicePrice.value);
        const targetCostPerMessage = Number(cost.value);
        const monthlyAdBudget = dailyBudget * 30;
        const messagePotential = Math.floor(monthlyAdBudget / targetCostPerMessage);
        const breakEvenJobs = Math.ceil(monthlyAdBudget / averageServicePrice);
        const extraScenarioJobs = Math.ceil(breakEvenJobs * 1.5);
        const extraScenarioRevenue = extraScenarioJobs * averageServicePrice;

        if (dailyLabel) dailyLabel.textContent = formatTRY(dailyBudget);
        if (servicePriceLabel) servicePriceLabel.textContent = formatTRY(averageServicePrice);
        if (costLabel) costLabel.textContent = formatTRY(targetCostPerMessage);
        if (monthlyBudget) monthlyBudget.textContent = formatTRY(monthlyAdBudget);
        if (estimatedMessages) estimatedMessages.textContent = `${messagePotential} mesaj`;
        if (breakEven) breakEven.textContent = `${breakEvenJobs} iş`;
        if (growthScenario) growthScenario.textContent = `${extraScenarioJobs} iş alınırsa ${formatTRY(extraScenarioRevenue)} servis hacmi oluşabilir.`;
        if (recommendation) recommendation.textContent = recommendations[service.value] || recommendations.Hepsi;
        if (areaNote) {
          areaNote.textContent = area.value.trim()
            ? `${area.value.trim()} bölgesi için planlama senaryosu. Garanti değildir.`
            : "Hizmet bölgesi girildiğinde senaryo o bölge için düşünülür.";
        }
      };

      [daily, area, service, servicePrice, cost].forEach((input) => input?.addEventListener("input", update));
      update();
    });
  </script>
</section>
