---
const mistakes = [
  {
    title: "Her hizmeti tek reklamda anlatmak",
    text: "Bakım isteyen kişiyle montaj isteyen kişi aynı mesaja aynı tepkiyi vermez.",
  },
  {
    title: "Messenger'a yönlendirip WhatsApp'ı kullanmamak",
    text: "Yerel servis işlerinde müşteri hızlı iletişim ister. WhatsApp akışı çoğu zaman daha doğal ilerler.",
  },
  {
    title: "Hizmet verilmeyen ilçelere reklam göstermek",
    text: "Yanlış bölgeden gelen mesajlar bütçeyi tüketir ama işe dönüşmez.",
  },
  {
    title: "Sadece fiyat soran kitleyi çekmek",
    text: "Reklam dili yanlışsa gelen mesajlar randevuya değil, sadece fiyat pazarlığına döner.",
  },
  {
    title: "Gelen mesajları ölçmeden bütçe artırmak",
    text: "Hangi hizmetten, hangi bölgeden ve hangi kreatiften mesaj geldiği takip edilmeden bütçe artırmak risklidir.",
  },
];
---

<section class="py-20 md:py-28">
  <div class="section-shell">
    <div class="mb-12 max-w-3xl">
      <h2 class="text-balance text-3xl font-black leading-tight text-white md:text-5xl">
        Klima firmalarının reklamda yaptığı 5 hata
      </h2>
      <p class="mt-5 text-base leading-8 text-textMuted md:text-lg">
        Reklam bütçesi çoğu zaman reklam kötü olduğu için değil, yanlış kurgulandığı için boşa gider.
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
      {mistakes.map((mistake, index) => (
        <article class="premium-card rounded-[8px] p-5">
          <span class="mb-6 inline-grid size-11 place-items-center rounded-[8px] border border-lime/30 bg-lime/10 text-sm font-black text-lime">
            0{index + 1}
          </span>
          <h3 class="text-lg font-black leading-7 text-white">{mistake.title}</h3>
          <p class="mt-3 text-sm leading-7 text-textMuted">{mistake.text}</p>
        </article>
      ))}
    </div>
  </div>
</section>
