---
import SectionHeader from "./SectionHeader.astro";
import Card from "./Card.astro";

const transparency = [
  {
    title: "Reklam bütçesi ayrı harcanır",
    text: "Reklam bütçesi Meta reklam hesabınızda harcanır, hizmet bedeline dahil değildir.",
  },
  {
    title: "Satış değil mesaj hedeflenir",
    text: "100 mesaj hedefi satış, randevu veya ödeme yapan müşteri garantisi değildir.",
  },
  {
    title: "Performans şehir, sezon ve bütçeye göre değişebilir",
    text: "Sonuçlar şehir, sezon, kreatif, bütçe ve firmanın dönüş hızına göre değişebilir.",
  },
  {
    title: "Gelen mesajların kalitesi birlikte değerlendirilir",
    text: "Sadece mesaj sayısı değil, hizmet ihtiyacı, bölge uygunluğu ve dönüş hızı da birlikte takip edilir.",
  },
];
---

<section id="100-mesaj" class="py-20 md:py-28">
  <div class="section-shell">
    <SectionHeader
      title="100 potansiyel müşteri mesajı hedefiyle çalışıyoruz"
      text="Aylık çalışmalarda hedefimiz, klima firmanız için minimum 100 potansiyel müşteri mesajı oluşturabilecek bir reklam sistemi kurmaktır. Bu hedef yalnızca reklamlar üzerinden gelen mesajlar için geçerlidir. Satış, randevu veya ödeme yapan müşteri garantisi değildir."
    />
    <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {transparency.map((item) => (
        <Card title={item.title} text={item.text} />
      ))}
    </div>
  </div>
</section>
