---
import CTAButton from "./CTAButton.astro";

const goodFit = [
  "Hizmet bölgesini net bilen",
  "WhatsApp mesajlarına hızlı dönen",
  "Reklam bütçesini düzenli yönetebilen",
  "Bakım, arıza, temizlik ve montaj tarafında büyümek isteyen",
];

const notFit = [
  "Her mesajı kesin satış gibi gören",
  "Reklam bütçesi ayırmadan sonuç bekleyen",
  "Gelen müşteriye geç dönen",
  "Hizmet bölgesi ve fiyat iletişimi belirsiz olan",
];
---

<section class="py-20 md:py-28">
  <div class="section-shell">
    <div class="glass-panel relative overflow-hidden rounded-[8px] p-6 md:p-10">
      <div class="absolute bottom-0 left-0 h-72 w-72 -translate-x-1/3 translate-y-1/3 rounded-full bg-lime/20 blur-3xl"></div>
      <div class="relative grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div>
          <p class="text-xs font-black uppercase tracking-[0.18em] text-lime">Uygunluk filtresi</p>
          <h2 class="mt-5 text-balance text-3xl font-black leading-tight text-white md:text-5xl">
            Sadece büyümek isteyen klima firmalarıyla çalışıyoruz
          </h2>
          <p class="mt-5 text-base leading-8 text-textMuted md:text-lg">
            Bu çalışma herkese uygun değildir. Reklamı “bir kere açalım bakalım” gibi değil, düzenli müşteri mesajı akışı kurmak isteyen firmalarla ilerleriz.
          </p>
          <p class="mt-4 text-sm font-semibold leading-7 text-white/75">
            Kendine güvenen, gelen mesaja sahip çıkan ve hizmet bölgesinde büyümek isteyen firmalar için daha doğru bir modeldir.
          </p>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <CTAButton href="#basvuru" label="Uygunluk Başvurusu Yap" />
            <CTAButton href="#100-mesaj" label="Şeffaflık Notunu Oku" variant="secondary" />
          </div>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <div class="rounded-[8px] border border-lime/25 bg-lime/[0.08] p-5">
            <div class="mb-5 flex items-center justify-between gap-3">
              <h3 class="text-lg font-black text-white">Kimlerle iyi çalışır?</h3>
              <span class="rounded-full bg-lime px-3 py-1 text-xs font-black text-ink">Uygun</span>
            </div>
            <div class="space-y-3">
              {goodFit.map((item) => (
                <button type="button" class="fit-chip group flex w-full items-start gap-3 rounded-[8px] border border-white/10 bg-[#111] p-3 text-left transition hover:border-lime/40 hover:bg-lime/10">
                  <span class="mt-1 size-2 shrink-0 rounded-full bg-lime"></span>
                  <span class="text-sm font-semibold leading-6 text-white/85 group-hover:text-white">{item}</span>
                </button>
              ))}
            </div>
          </div>

          <div class="rounded-[8px] border border-white/10 bg-[#101010] p-5">
            <div class="mb-5 flex items-center justify-between gap-3">
              <h3 class="text-lg font-black text-white">Kimler için uygun değil?</h3>
              <span class="rounded-full border border-white/10 px-3 py-1 text-xs font-black text-textMuted">Netlik</span>
            </div>
            <div class="space-y-3">
              {notFit.map((item) => (
                <button type="button" class="fit-chip group flex w-full items-start gap-3 rounded-[8px] border border-white/10 bg-white/[0.03] p-3 text-left transition hover:border-white/25 hover:bg-white/[0.06]">
                  <span class="mt-1 size-2 shrink-0 rounded-full bg-white/35"></span>
                  <span class="text-sm font-semibold leading-6 text-textMuted group-hover:text-white/85">{item}</span>
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
