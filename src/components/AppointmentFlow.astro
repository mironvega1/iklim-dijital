---
const steps = [
  "Reklamı görür",
  "WhatsApp'tan yazar",
  "İlçe, hizmet ve klima adedi alınır",
  "Uygun saat ve fiyat bilgisi netleşir",
  "Servis planlanır",
];
---

<section class="py-20 md:py-28">
  <div class="section-shell">
    <div class="mb-12 max-w-3xl">
      <h2 class="text-balance text-3xl font-black leading-tight text-white md:text-5xl">
        Mesajdan randevuya giden akış
      </h2>
      <p class="mt-5 text-base leading-8 text-textMuted md:text-lg">
        Amaç yalnızca mesaj almak değil, gelen talebi doğru bilgiyle randevuya yaklaştırmaktır.
      </p>
    </div>

    <div class="grid gap-4 lg:grid-cols-5">
      {steps.map((step, index) => (
        <article class="premium-card relative rounded-[8px] p-6">
          <span class="mb-6 inline-grid size-12 place-items-center rounded-full bg-lime text-sm font-black text-ink">{index + 1}</span>
          <h3 class="text-lg font-black leading-7 text-white">{step}</h3>
          {index < steps.length - 1 && <span class="absolute -right-2 top-12 hidden h-px w-4 bg-lime/50 lg:block" aria-hidden="true"></span>}
        </article>
      ))}
    </div>
  </div>
</section>
