---
import CTAButton from "./CTAButton.astro";

const checks = [
  "Klima bakım, temizlik, arıza veya montaj hizmeti veriyorsanız",
  "Günlük reklam bütçesi ayırabiliyorsanız",
  "WhatsApp mesajlarına hızlı dönüş yapabiliyorsanız",
  "Hizmet verdiğiniz ilçeler netse",
  "Daha düzenli müşteri mesajı istiyorsanız",
];
---

<section class="py-20 md:py-28">
  <div class="section-shell">
    <div class="glass-panel grid gap-8 rounded-[8px] p-6 md:p-10 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
      <div>
        <p class="text-xs font-black uppercase text-lime">Uygunluk kontrolü</p>
        <h2 class="mt-4 text-balance text-3xl font-black leading-tight text-white md:text-5xl">
          Bu sistem size uygun mu?
        </h2>
        <p class="mt-5 text-base leading-8 text-textMuted">
          Kendine güvenen, gelen mesaja hızlı dönen ve hizmet bölgesinde büyümek isteyen klima firmaları için daha doğru çalışır.
        </p>
        <CTAButton href="#basvuru" label="Uygunluk Başvurusu Yap" class="mt-8" />
      </div>

      <div class="grid gap-3 md:grid-cols-2">
        {checks.map((check) => (
          <div class="rounded-[8px] border border-lime/20 bg-lime/[0.07] p-4">
            <span class="mb-3 inline-grid size-7 place-items-center rounded-full bg-lime text-sm font-black text-ink">✓</span>
            <p class="text-sm font-bold leading-6 text-white">{check}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
