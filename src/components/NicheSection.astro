---
import SectionHeader from "./SectionHeader.astro";
import Card from "./Card.astro";

const advantages = [
  {
    title: "Sektör dilini biliyoruz",
    text: "Klima müşterisinin aciliyeti, fiyat hassasiyeti ve hizmet beklentisi farklıdır.",
    detail: "Klima müşterisi bazen hemen servis ister, bazen yaz gelmeden bakım arar. Mesaj dili bu farkı yakalamalıdır.",
  },
  {
    title: "Hizmet türüne göre reklam açısı kuruyoruz",
    text: "Bakım, arıza, temizlik ve montaj için aynı metinle reklam çıkmayız.",
    detail: "Her hizmet ayrı niyet taşır. Bu yüzden reklam metni, görsel açı ve WhatsApp konuşması hizmete göre ayrılır.",
  },
  {
    title: "WhatsApp mesaj akışını randevuya uygun hale getiriyoruz",
    text: "Mesajın hızlıca hizmet bölgesi, ihtiyaç ve uygun zaman konuşmasına dönmesini hedefleriz.",
    detail: "İlk konuşma doğru kurulursa müşteriyle gereksiz mesaj trafiği azalır ve randevu ihtimali daha net anlaşılır.",
  },
];
---

<section class="py-20 md:py-28">
  <div class="section-shell">
    <SectionHeader
      title="Her sektöre değil, sadece klima firmalarına odaklanıyoruz"
      text="Klima sektöründe müşteri davranışı farklıdır. Bakım isteyen müşteriyle montaj isteyen müşteri aynı şekilde karar vermez. Bu yüzden reklam sistemi de sektöre özel kurulmalıdır."
    />
    <div class="mt-12 grid gap-4 md:grid-cols-3">
      {advantages.map((item) => (
        <Card title={item.title} text={item.text} detail={item.detail} actionLabel="Neden önemli?" />
      ))}
    </div>
  </div>
</section>
