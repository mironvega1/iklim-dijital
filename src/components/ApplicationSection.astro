---
import { siteConfig } from "../config";

const services = [
  "Klima bakım",
  "Klima temizlik",
  "Klima arıza",
  "Klima montaj / sökme-takma",
  "Hepsi",
];
---

<section id="basvuru" class="py-20 md:py-28">
  <div class="section-shell">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="lg:sticky lg:top-28">
        <p class="mb-4 text-xs font-extrabold uppercase text-lime">Başvuru</p>
        <h2 class="text-balance text-3xl font-black leading-tight text-white md:text-5xl">
          Başvurunuzu gönderin, firmanız için uygunluğu değerlendirelim
        </h2>
        <p class="mt-5 text-base leading-8 text-textMuted md:text-lg">
          Hizmet bölgenizi, günlük reklam bütçenizi ve en çok müşteri almak istediğiniz hizmeti paylaşın. Size uygun bir reklam sistemi kurulup kurulamayacağını birlikte değerlendirelim.
        </p>
        <div class="mt-8 rounded-[8px] border border-white/10 bg-white/[0.035] p-5">
          <div class="space-y-3 text-sm font-semibold leading-6 text-textMuted">
            <p>• Bilgileriniz yalnızca başvuru için kullanılır.</p>
            <p>• Başvuru WhatsApp üzerinden iletilir.</p>
            <p>• Fiyat ve çalışma modeli görüşmede netleşir.</p>
          </div>
          <a
            href={siteConfig.instagramUrl}
            target="_blank"
            rel="noreferrer"
            class="mt-4 inline-flex text-sm font-bold text-lime transition hover:text-white"
          >
            Instagram: @iklimdijital
          </a>
          <p class="mt-2 text-xs font-semibold text-textMuted">Instagram'da bizi inceleyin.</p>
        </div>
        <div class="mt-4 grid gap-3 sm:grid-cols-2">
          <button type="button" class="rounded-[8px] border border-white/10 bg-[#101010] p-4 text-left transition hover:border-lime/35 hover:bg-lime/[0.07]">
            <p class="text-xs font-black uppercase text-lime">Veri saklanmaz</p>
            <p class="mt-2 text-xs font-semibold leading-6 text-textMuted">Form bilgileri tarayıcıda tutulmaz; WhatsApp mesajına çevrilir.</p>
          </button>
          <button type="button" class="rounded-[8px] border border-white/10 bg-[#101010] p-4 text-left transition hover:border-lime/35 hover:bg-lime/[0.07]">
            <p class="text-xs font-black uppercase text-lime">Secret yok</p>
            <p class="mt-2 text-xs font-semibold leading-6 text-textMuted">Frontend içinde API key, token veya gizli entegrasyon bulunmaz.</p>
          </button>
        </div>
      </div>

      <form
        id="application-form"
        class="glass-panel rounded-[8px] p-4 min-[380px]:p-5 md:p-8"
        data-whatsapp-number={siteConfig.whatsappNumber}
        data-form-action={siteConfig.formAction}
        novalidate
      >
        <div class="grid gap-4 md:grid-cols-2">
          <label class="block">
            <span class="text-sm font-bold text-white">Ad Soyad <span class="text-lime">*</span></span>
            <input required name="Ad Soyad" type="text" autocomplete="name" class="mt-2 h-12 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 text-sm text-white outline-none transition placeholder:text-textMuted focus:border-lime/50" placeholder="Adınız ve soyadınız" />
          </label>
          <label class="block">
            <span class="text-sm font-bold text-white">Firma Adı</span>
            <input name="Firma" type="text" autocomplete="organization" class="mt-2 h-12 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 text-sm text-white outline-none transition placeholder:text-textMuted focus:border-lime/50" placeholder="Firma adınız" />
          </label>
          <label class="block">
            <span class="text-sm font-bold text-white">Telefon Numarası <span class="text-lime">*</span></span>
            <input required name="Telefon" type="tel" inputmode="tel" autocomplete="tel" class="mt-2 h-12 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 text-sm text-white outline-none transition placeholder:text-textMuted focus:border-lime/50" placeholder="05xx xxx xx xx" />
          </label>
          <label class="block">
            <span class="text-sm font-bold text-white">Şehir / İlçe <span class="text-lime">*</span></span>
            <input required name="Şehir / İlçe" type="text" autocomplete="address-level2" class="mt-2 h-12 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 text-sm text-white outline-none transition placeholder:text-textMuted focus:border-lime/50" placeholder="İstanbul / Kadıköy" />
          </label>
          <label class="block">
            <span class="text-sm font-bold text-white">Hizmet Bölgesi</span>
            <input name="Hizmet Bölgesi" type="text" class="mt-2 h-12 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 text-sm text-white outline-none transition placeholder:text-textMuted focus:border-lime/50" placeholder="Çalıştığınız semtler" />
          </label>
          <label class="block">
            <span class="text-sm font-bold text-white">Günlük Reklam Bütçesi <span class="text-lime">*</span></span>
            <input required name="Günlük Reklam Bütçesi" type="text" class="mt-2 h-12 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 text-sm text-white outline-none transition placeholder:text-textMuted focus:border-lime/50" placeholder="Örn. günlük 500 TL" />
          </label>
          <label class="block md:col-span-2">
            <span class="text-sm font-bold text-white">En Çok Müşteri Almak İstediğiniz Hizmet</span>
            <select name="İstenen Hizmet" class="mt-2 h-12 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 text-sm text-white outline-none transition focus:border-lime/50">
              {services.map((service) => <option value={service}>{service}</option>)}
            </select>
          </label>
          <fieldset class="md:col-span-2">
            <legend class="text-sm font-bold text-white">Şu Anda Reklam Veriyor musunuz?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              <label class="flex min-h-12 items-center gap-2 rounded-[8px] border border-white/10 bg-[#151515] px-4 py-3 text-sm font-semibold text-white">
                <input type="radio" name="Şu anda reklam veriyor mu" value="Evet" class="accent-lime" />
                Evet
              </label>
              <label class="flex min-h-12 items-center gap-2 rounded-[8px] border border-white/10 bg-[#151515] px-4 py-3 text-sm font-semibold text-white">
                <input type="radio" name="Şu anda reklam veriyor mu" value="Hayır" class="accent-lime" />
                Hayır
              </label>
              <label class="flex min-h-12 items-center gap-2 rounded-[8px] border border-white/10 bg-[#151515] px-4 py-3 text-sm font-semibold text-white sm:col-span-2">
                <input type="radio" name="Şu anda reklam veriyor mu" value="Daha önce verdim ama sonuç alamadım" class="accent-lime" />
                Daha önce verdim ama sonuç alamadım
              </label>
            </div>
          </fieldset>
          <label class="block md:col-span-2">
            <span class="text-sm font-bold text-white">Ek Not</span>
            <textarea name="Not" rows="4" class="mt-2 w-full rounded-[8px] border border-white/10 bg-[#151515] px-4 py-3 text-sm text-white outline-none transition placeholder:text-textMuted focus:border-lime/50" placeholder="Kısaca mevcut durumunuzu yazabilirsiniz"></textarea>
          </label>
        </div>

        <p id="form-error" class="mt-5 hidden rounded-[8px] border border-lime/30 bg-lime/10 p-4 text-sm font-semibold text-white"></p>
        <button type="submit" class="mt-6 inline-flex min-h-12 w-full items-center justify-center rounded-full bg-lime px-6 py-3 text-sm font-black text-ink shadow-[0_18px_50px_rgba(147,200,62,0.22)] transition hover:bg-white">
          Başvuruyu WhatsApp ile Gönder
        </button>
      </form>
    </div>
  </div>

  <script>
    const form = document.getElementById("application-form");
    const errorBox = document.getElementById("form-error");

    form?.addEventListener("submit", (event) => {
      event.preventDefault();
      const formElement = event.currentTarget;
      if (!(formElement instanceof HTMLFormElement)) return;

      const requiredFields = Array.from(formElement.querySelectorAll("[required]"));
      const missingField = requiredFields.find((field) => field instanceof HTMLInputElement && !field.value.trim());
      const phoneInput = formElement.querySelector('input[name="Telefon"]');
      const phoneValue = phoneInput instanceof HTMLInputElement ? phoneInput.value.trim() : "";
      const digitCount = phoneValue.replace(/\D/g, "").length;

      if (missingField) {
        if (errorBox) {
          errorBox.textContent = "Lütfen zorunlu alanları doldurun.";
          errorBox.classList.remove("hidden");
        }
        return;
      }

      if (digitCount < 10) {
        if (errorBox) {
          errorBox.textContent = "Lütfen geçerli bir telefon numarası girin.";
          errorBox.classList.remove("hidden");
        }
        return;
      }

      if (errorBox) errorBox.classList.add("hidden");

      const formAction = formElement.dataset.formAction || "";
      if (formAction) {
        formElement.action = formAction;
        formElement.method = "POST";
        formElement.submit();
        return;
      }

      const data = new FormData(formElement);
      const lines = [
        "Merhaba, İklimDijital başvuru formundan geldim.",
        "",
        `Ad Soyad: ${data.get("Ad Soyad") || ""}`,
        `Firma: ${data.get("Firma") || ""}`,
        `Telefon: ${data.get("Telefon") || ""}`,
        `Şehir / İlçe: ${data.get("Şehir / İlçe") || ""}`,
        `Hizmet Bölgesi: ${data.get("Hizmet Bölgesi") || ""}`,
        `Günlük Reklam Bütçesi: ${data.get("Günlük Reklam Bütçesi") || ""}`,
        `İstenen Hizmet: ${data.get("İstenen Hizmet") || ""}`,
        `Şu Anda Reklam Veriyor mu: ${data.get("Şu anda reklam veriyor mu") || ""}`,
        `Not: ${data.get("Not") || ""}`,
      ];
      const number = formElement.dataset.whatsappNumber || "905449652314";
      window.location.href = `https://wa.me/${number}?text=${encodeURIComponent(lines.join("\n"))}`;
    });
  </script>
</section>
