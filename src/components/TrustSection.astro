---
import SectionHeader from "./SectionHeader.astro";
import Card from "./Card.astro";

const trustItems = [
  "Reklam bütçesi sizin hesabınızda harcanır",
  "Gelen mesajlar WhatsApp üzerinden takip edilir",
  "Aylık performans raporu sunulur",
];
---

<section class="py-20 md:py-28">
  <div class="section-shell">
    <SectionHeader
      title="Şeffaf reklam yönetimi, net hedefler"
      text="Reklam bütçesi müşterinin kendi Meta reklam hesabında harcanır. Kampanya performansı, mesaj maliyeti ve gelen talepler düzenli olarak takip edilir."
    />
    <div class="mt-12 grid gap-4 md:grid-cols-3">
      {trustItems.map((item, index) => (
        <Card title={item}>
          <div class="mb-5 grid size-10 place-items-center rounded-[8px] border border-lime/30 bg-lime/10 text-xs font-black text-lime">
            {index + 1}
          </div>
        </Card>
      ))}
    </div>

    <div class="mt-8 rounded-[8px] border border-dashed border-white/15 bg-white/[0.03] p-6 text-center md:p-8">
      <span class="inline-flex rounded-full border border-white/10 bg-white/[0.04] px-4 py-2 text-xs font-bold uppercase text-textMuted">
        Gerçek veriyle güncellenecek
      </span>
      <h3 class="mt-5 text-2xl font-black text-white">Gerçek sonuçlar geldikçe burada paylaşacağız</h3>
      <p class="mx-auto mt-3 max-w-2xl text-sm leading-7 text-textMuted">
        Müşteri geri bildirimleri ve kampanya sonuçları onay alındığında bu bölümde yayınlanacaktır.
      </p>
    </div>
  </div>
</section>
