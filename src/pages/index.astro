---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ProblemSection from "../components/ProblemSection.astro";
import NoAdsComparison from "../components/NoAdsComparison.astro";
import MistakesSection from "../components/MistakesSection.astro";
import SystemComparison from "../components/SystemComparison.astro";
import ScopeSection from "../components/ScopeSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import AppointmentFlow from "../components/AppointmentFlow.astro";
import TargetSection from "../components/TargetSection.astro";
import FitChecklist from "../components/FitChecklist.astro";
import ApplicationSection from "../components/ApplicationSection.astro";
import NicheSection from "../components/NicheSection.astro";
import FAQSection from "../components/FAQSection.astro";
import FinalCTA from "../components/FinalCTA.astro";
import Footer from "../components/Footer.astro";
import CTAButton from "../components/CTAButton.astro";
---

<BaseLayout>
  <Header />
  <main>
    <Hero />
    <ProblemSection />
    <NoAdsComparison />
    <MistakesSection />
    <SystemComparison />
    <ScopeSection />
    <ServicesSection />
    <AppointmentFlow />
    <TargetSection />
    <FitChecklist />
    <ApplicationSection />
    <NicheSection />
    <FAQSection />
    <FinalCTA />
  </main>
  <Footer />
  <div class="mobile-whatsapp fixed inset-x-0 bottom-0 z-40 border-t border-white/10 bg-ink/90 p-3 backdrop-blur-2xl md:hidden">
    <CTAButton label="WhatsApp'tan Bilgi Al" class="w-full" />
  </div>
</BaseLayout>
